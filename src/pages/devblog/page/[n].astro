---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogIndex from "@/components/BlogIndex.astro";
import { listAllTags, listPosts } from "@/lib/blog";

const nParam = Astro.params.n;
const pageNum = nParam ? parseInt(nParam, 10) : NaN;

if (Number.isNaN(pageNum) || pageNum < 2) {
  return Astro.redirect("/devblog/");
}

const tagParam = Astro.url.searchParams.get("tag");
const activeTag = tagParam && tagParam.length > 0 ? tagParam : null;

const [paginated, allTags] = await Promise.all([
  listPosts({ page: pageNum, tag: activeTag }),
  listAllTags(),
]);

if (paginated.items.length === 0) {
  return Astro.redirect("/devblog/");
}

const titleSuffix = activeTag ? ` — ${activeTag}` : "";
---

<BaseLayout
  title={`Dev-блог${titleSuffix} (страница ${pageNum})`}
  description={`Dev-блог автора сайта CodeDocSS — страница ${pageNum}.`}
  ogType="website"
>
  <BlogIndex paginated={paginated} allTags={allTags} activeTag={activeTag} />
</BaseLayout>
