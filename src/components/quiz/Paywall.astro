---
interface Props {
  text?: string;
}
const { text = "Эта проверка знаний доступна по подписке." } = Astro.props;
---

<div
  class="my-6 flex items-start gap-3 rounded-lg border border-dashed border-[var(--color-card-border)] bg-[var(--color-card-bg)] p-4"
  role="note"
  aria-label="Контент по подписке"
>
  <div class="mt-0.5 text-[var(--color-link-hover)]" aria-hidden="true">
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>
  </div>
  <div class="flex-1">
    <p class="m-0 font-medium">{text}</p>
    <p class="m-0 mt-1 text-sm text-white/60">
      Подписка пока в разработке — мы откроем доступ, как только подключим оплату.
    </p>
    <button
      type="button"
      disabled
      class="mt-3 inline-flex cursor-not-allowed items-center gap-2 rounded-md border border-[var(--color-card-border)] px-3 py-1.5 text-sm opacity-60"
    >
      Подписаться (скоро)
    </button>
  </div>
</div>
