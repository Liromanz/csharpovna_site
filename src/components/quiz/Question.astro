---
interface Props {
  prompt: string;
  /** "exact" — точное сравнение строки, "code-runtime" — реальный запуск кода (на бэке). */
  checkType?: "exact" | "code-runtime";
  placeholder?: string;
}

const { prompt, checkType = "exact", placeholder } = Astro.props;
---

<div class="quiz-question my-4" data-quiz-question data-check-type={checkType}>
  <p class="m-0 mb-3 font-medium">{prompt}</p>
  <textarea
    data-quiz-input
    rows="3"
    placeholder={placeholder ?? "Ваш ответ..."}
    class="w-full rounded-md border border-[var(--color-card-border)] bg-black/30 p-3 font-mono text-sm focus:border-[var(--color-link)] focus:outline-none"
  ></textarea>
  <div class="mt-3 flex items-center gap-3">
    <button
      type="button"
      data-quiz-check
      class="rounded-md bg-[var(--color-success)] px-3 py-1.5 text-sm font-medium text-white hover:opacity-90"
    >
      Проверить
    </button>
    <span data-quiz-result class="text-sm" aria-live="polite"></span>
  </div>
</div>

<script>
  const STORAGE_KEY = "codedocss-fingerprint";

  function fingerprint(): string {
    try {
      let fp = localStorage.getItem(STORAGE_KEY);
      if (!fp) {
        fp = Array.from(crypto.getRandomValues(new Uint8Array(16)))
          .map((b) => b.toString(16).padStart(2, "0"))
          .join("");
        localStorage.setItem(STORAGE_KEY, fp);
      }
      return fp;
    } catch { return "anon"; }
  }

  document.querySelectorAll<HTMLElement>("[data-quiz-question]").forEach((el) => {
    const btn = el.querySelector<HTMLButtonElement>("[data-quiz-check]");
    const input = el.querySelector<HTMLTextAreaElement>("[data-quiz-input]");
    const result = el.querySelector<HTMLElement>("[data-quiz-result]");
    const quiz = el.closest<HTMLElement>("[data-quiz]");
    const lessonSlug = quiz?.dataset.quizSlug ?? "";
    const questionId = quiz?.dataset.quizId ?? "";

    btn?.addEventListener("click", async () => {
      if (!input || !result) return;
      btn.disabled = true;
      result.textContent = "Проверяем...";
      result.className = "text-sm text-white/60";
      try {
        const res = await fetch("/api/quiz/check", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({
            lessonSlug,
            questionId,
            answer: input.value,
            fingerprint: fingerprint(),
          }),
        });
        if (res.status === 501) {
          result.textContent = "Проверка временно недоступна.";
          result.className = "text-sm text-yellow-400";
          return;
        }
        const data = await res.json();
        if (data.correct) {
          result.textContent = "✓ Верно!";
          result.className = "text-sm text-[var(--color-success)] font-medium";
        } else {
          result.textContent = "✗ Не совсем — попробуй ещё раз";
          result.className = "text-sm text-[var(--color-danger)]";
        }
      } catch {
        result.textContent = "Ошибка соединения";
        result.className = "text-sm text-[var(--color-danger)]";
      } finally {
        btn.disabled = false;
      }
    });
  });
</script>
