---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  /** Минимальный уровень (h2 = 2). По умолчанию 2-3. */
  minDepth?: number;
  maxDepth?: number;
}

const { headings, minDepth = 2, maxDepth = 3 } = Astro.props;
const filtered = headings.filter((h) => h.depth >= minDepth && h.depth <= maxDepth);

// Сгруппируем h3 под их предшествующий h2, чтобы рендерить вложенным <ul>.
type TocNode = { heading: MarkdownHeading; children: MarkdownHeading[] };
const tree: TocNode[] = [];
for (const h of filtered) {
  if (h.depth === 2 || tree.length === 0) {
    tree.push({ heading: h, children: [] });
  } else {
    tree[tree.length - 1].children.push(h);
  }
}

const stripAnchor = (text: string) => text.replace(/\s*#\s*$/, "");
---

{filtered.length > 0 && (
  <aside class="mb-8 not-prose">
    <p class="m-0 mb-3 text-xs font-semibold uppercase tracking-wider text-white/50">Содержание</p>
    <ul class="m-0 list-disc space-y-0.5 pl-5 text-sm marker:text-[var(--color-link)]">
      {tree.map((node) => (
        <li>
          <a
            href={`#${node.heading.slug}`}
            class="block py-1 text-white/70 transition-colors hover:text-white hover:no-underline"
          >
            {stripAnchor(node.heading.text)}
          </a>
          {node.children.length > 0 && (
            <ul class="m-0 list-[circle] space-y-0.5 pl-5 marker:text-[var(--color-link)]">
              {node.children.map((child) => (
                <li>
                  <a
                    href={`#${child.slug}`}
                    class="block py-1 text-white/70 transition-colors hover:text-white hover:no-underline"
                  >
                    {stripAnchor(child.text)}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </aside>
)}
