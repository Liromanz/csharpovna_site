---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  /** Минимальный уровень (h2 = 2). По умолчанию 2-3. */
  minDepth?: number;
  maxDepth?: number;
}

const { headings, minDepth = 2, maxDepth = 3 } = Astro.props;
const filtered = headings.filter((h) => h.depth >= minDepth && h.depth <= maxDepth);
---

{filtered.length > 0 && (
  <aside class="mb-6 rounded-lg border border-[var(--color-card-border)] bg-[var(--color-card-bg)] p-4">
    <h2 class="m-0 mb-2 text-base font-semibold text-[var(--color-link-hover)]">Содержание</h2>
    <ul class="m-0 list-none space-y-1 p-0 text-sm">
      {filtered.map((h) => (
        <li class:list={[h.depth === 3 && "ml-4"]}>
          <a href={`#${h.slug}`} class="text-[var(--color-link)] hover:underline">{h.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}
