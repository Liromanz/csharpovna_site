---
import { buildSeo, type SeoData } from "@/lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  keywords?: string[];
  publishedTime?: Date;
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogType, ogImage, keywords, publishedTime, jsonLd } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const seo: SeoData = buildSeo({ title, description, canonical, ogType, ogImage, keywords, publishedTime, jsonLd });
const ogImg = seo.ogImage ?? new URL("/img/safika.png", Astro.site).toString();
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
{seo.keywords && seo.keywords.length > 0 && <meta name="keywords" content={seo.keywords.join(", ")} />}

<meta property="og:type" content={seo.ogType} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={ogImg} />
<meta property="og:site_name" content="CodeDocSS" />
<meta property="og:locale" content="ru_RU" />
{seo.publishedTime && <meta property="article:published_time" content={seo.publishedTime.toISOString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={ogImg} />

{seo.jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
)}
