---
import { sections, type SectionId } from "@/data/sections";

interface Props {
  currentSection: SectionId;
  currentSlug?: string;
}

const { currentSection, currentSlug } = Astro.props;
const section = sections[currentSection];
---

<nav
  id="sidebar"
  class="sidebar-scroll fixed inset-y-0 left-0 z-40 w-[var(--spacing-sidebar)] -translate-x-full overflow-y-auto bg-[var(--color-sidebar)] text-[var(--color-sidebar-fg)] transition-transform duration-300 data-[open=true]:translate-x-0 md:sticky md:top-0 md:h-screen md:translate-x-0"
  aria-label="Навигация раздела"
>
  <div class="px-4 py-5">
    <h2 class="text-center text-lg font-semibold text-[var(--color-sidebar-header)]">
      {currentSection === "csharp" && "C# — базовые структуры"}
      {currentSection === "wpf" && "WPF"}
      {currentSection === "java" && "Java"}
    </h2>
    <hr class="my-3 border-[var(--color-sidebar-border)]" />

    {section.status === "coming-soon" ? (
      <p class="px-2 py-3 text-sm leading-relaxed text-white/70">{section.comingSoonText}</p>
    ) : (
      <ul class="list-none space-y-1 p-0">
        {section.groups.map((group) => (
          <li>
            <details
              class="group"
              open={!!currentSlug && group.items.some((it) => it.slug === currentSlug)}
            >
              <summary
                class="flex cursor-pointer select-none items-center justify-between rounded px-2 py-1.5 text-sm font-semibold text-white/80 transition-colors hover:text-white [&::-webkit-details-marker]:hidden"
              >
                <span>{group.title}</span>
                <svg
                  class="h-3 w-3 shrink-0 text-white/40 transition-transform duration-200 group-open:rotate-90"
                  viewBox="0 0 12 12"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 2 L8 6 L4 10" />
                </svg>
              </summary>
              <ul class="mt-0.5 mb-1 list-none p-0">
                {group.items.map((item) => {
                  const href = `${section.basePath}/${item.slug}`;
                  const isActive = item.slug === currentSlug;
                  return (
                    <li>
                      <a
                        href={href}
                        class:list={[
                          "block border-l py-1.5 pl-4 pr-2 text-sm leading-snug transition-colors hover:no-underline",
                          isActive
                            ? "border-[var(--color-link)] font-medium text-white"
                            : "border-transparent text-white/70 hover:border-white/20 hover:text-white",
                          item.placeholder && !isActive && "italic text-white/45",
                        ]}
                        aria-current={isActive ? "page" : undefined}
                      >
                        {item.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </details>
          </li>
        ))}
      </ul>
    )}
  </div>
</nav>

<div
  id="sidebar-overlay"
  class="fixed inset-0 z-30 hidden bg-[var(--color-overlay)] data-[open=true]:block md:!hidden"
  aria-hidden="true"
></div>
